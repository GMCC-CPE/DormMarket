@page "{id}"
@model GMCC.Pages.ManageDormOwner
@{
    ViewData["Title"] = $"Editing: {Model.DormitoryName}";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f9fafb;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
            color: #1f2937;
        }

        .owner-badge {
            background: #d1fae5;
            color: #047857;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 999px;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-links a {
            text-decoration: none;
            color: #6b7280;
            font-size: 14px;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #d1d5db;
        }

        .container {
            max-width: 760px;
            margin: 0 auto;
            padding: 28px 32px 60px;
        }

        .header-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 28px;
        }

        .page-title {
            font-size: 16px;
            font-weight: 700;
        }

        .header-actions {
            display: flex;
            gap: 10px;
        }

        .btn-delete {
            background: #99f6e4;
            color: #0f766e;
            border: none;
            border-radius: 8px;
            padding: 10px 18px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-save {
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 18px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
        }

        .section-title {
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.04em;
            color: #374151;
            margin-bottom: 16px;
        }

        .rooms-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .rooms-table th {
            text-align: left;
            font-size: 11px;
            font-weight: 800;
            color: #9ca3af;
            letter-spacing: 0.04em;
            padding-bottom: 10px;
            border-bottom: 1px solid #e5e7eb;
        }

        .rooms-table td {
            padding: 12px 10px 12px 0;
            border-bottom: 1px solid #f3f4f6;
            font-size: 14px;
            color: #1f2937;
        }

        .text-input {
            width: 100%;
            max-width: 160px;
            padding: 6px 10px;
            border: 1px solid transparent;
            border-radius: 6px;
            font-size: 13px;
            color: #1f2937;
            background: transparent;
        }

        .text-input:hover, .text-input:focus {
            border-color: #d1d5db;
            background: #fff;
        }

        .price-input {
            width: 100px;
            padding: 6px 10px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: #f3f4f6;
            font-size: 13px;
            color: #374151;
        }

        .avail-pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 12px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 999px;
            background: #f3f4f6;
            color: #6b7280;
            cursor: pointer;
            margin-right: 8px;
        }

        .avail-pill:has(input:checked) {
            background: #d1fae5;
            color: #047857;
        }

        .avail-pill input {
            display: none;
        }

        .btn-add-room {
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="navbar-left">
            <span class="navbar-brand">DormMarket</span>
            <span class="owner-badge">Owner</span>
        </div>
        <div class="navbar-links">
            <a asp-page="/DashboardOwner">Dashboard</a>
            <a asp-page="/ProfileOwner">Profile</a>
        </div>
        <div class="avatar-circle"></div>
    </nav>

    <div class="container">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="DormitoryName" />

            <div class="header-row">
                <div class="page-title">Editing: @Model.DormitoryName</div>
                <div class="header-actions">
                    <button type="submit" asp-page-handler="DeleteListing" class="btn-delete"
                            onclick="return confirm('Delete &quot;@Model.DormitoryName&quot;? This cannot be undone.');">
                        DELETE LISTING
                    </button>
                    <button type="submit" asp-page-handler="SaveChanges" class="btn-save">SAVE CHANGES</button>
                </div>
            </div>

            <p class="section-title">ROOMS</p>

            <table class="rooms-table">
                <thead>
                    <tr>
                        <th>ROOM TYPE</th>
                        <th>PRICE/MONTH</th>
                        <th>AVAILABILITY</th>
                    </tr>
                </thead>
                <tbody id="roomsBody">
                    @for (int i = 0; i < Model.Rooms.Count; i++)
                    {
                        var room = Model.Rooms[i];
                        <tr>
                            <td>
                                <input type="text" name="Rooms[@i].RoomType" value="@room.RoomType" class="text-input" />
                            </td>
                            <td>
                                <input type="text" name="Rooms[@i].Price" value="@room.Price" class="price-input" />
                            </td>
                            <td>
                                <label class="avail-pill">
                                    <input type="radio" name="Rooms[@i].Availability" value="Available" checked="@(room.Availability == "Available" ? "checked" : null)" />
                                    Available
                                </label>
                                <label class="avail-pill">
                                    <input type="radio" name="Rooms[@i].Availability" value="Full" checked="@(room.Availability == "Full" ? "checked" : null)" />
                                    Full
                                </label>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <button type="button" id="addRoomBtn" class="btn-add-room">+ Add Room Type</button>
        </form>
    </div>

    <script>
        (function () {
            var addBtn = document.getElementById('addRoomBtn');
            var tbody = document.getElementById('roomsBody');
            var rowCount = @Model.Rooms.Count;

            addBtn.addEventListener('click', function () {
                var index = rowCount++;
                var tr = document.createElement('tr');
                tr.innerHTML =
                    '<td><input type="text" name="Rooms[' + index + '].RoomType" placeholder="Room type" class="text-input" /></td>' +
                    '<td><input type="text" name="Rooms[' + index + '].Price" placeholder="P 0" class="price-input" /></td>' +
                    '<td>' +
                        '<label class="avail-pill"><input type="radio" name="Rooms[' + index + '].Availability" value="Available" checked /> Available</label>' +
                        '<label class="avail-pill"><input type="radio" name="Rooms[' + index + '].Availability" value="Full" /> Full</label>' +
                    '</td>';
                tbody.appendChild(tr);
            });
        })();
    </script>
</body>
</html>
